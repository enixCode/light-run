# Copy to .env and adjust. All variables are optional.
# Consumed by docker-compose.yml (dev). The CLI reads the same names.

# Bearer token required on every non-/health route.
# Omit to leave the server open (a warning prints at startup).
# Generate one with: openssl rand -hex 32
LIGHT_RUN_TOKEN=

# Host port mapped to the container's 3001. Default: 3001.
LIGHT_RUN_PORT=3001

# Max POST body size in bytes. Default: 10485760 (10 MiB).
# Each request is parsed in memory, so raising this is a memory-per-request cost.
LIGHT_RUN_BODY_LIMIT=10485760

# Total bytes across all artifact dirs before auto-eviction kicks in.
# Default: 21474836480 (20 GiB).
LIGHT_RUN_MAX_ARTIFACTS_BYTES=21474836480
